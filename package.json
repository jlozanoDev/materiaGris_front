{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,vue}\"",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,vue,json,css,md}\"",
    "prepare": "husky install",
    "test:e2e": "playwright test",
    "quality": "npm run lint && npm run typecheck && npm run test:run",
    "verify": "npm run quality && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@tanstack/vue-table": "^8.21.3",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@tiptap/vue-3": "^3.26.1",
    "animejs": "^4.4.1",
    "html2pdf.js": "^0.14.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "sass": "^1.99.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "vuetify": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.1",
    "eslint": "^8.41.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.13.0",
    "husky": "^8.0.3",
    "jsdom": "^22.1.0",
    "lint-staged": "^14.0.1",
    "prettier": "^2.8.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.0",
    "vite": "^8.0.1",
    "vitest": "^1.1.4",
    "vue-tsc": "~2.2.0"
  }
}
